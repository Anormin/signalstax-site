</div>

<!-- ── BODY ── -->
<div class="intake-body" id="intakeBody">

  <!-- MAIN FORM AREA -->
  <div id="formArea">

    <!-- SUCCESS STATE -->
    <div class="success-panel" id="successPanel">
      <div class="success-icon">
        <svg viewBox="0 0 32 32" fill="none"><path d="M6 16l7 7L26 9" stroke="#1DBC7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="success-title">PROFILE<br><em>SUBMITTED.</em></div>
      <p class="success-sub">We've received your player's information. Your full Player Development Score and metric breakdown will be ready within 48 hours.</p>
      <div class="success-detail">
        <div class="sd-item">
          <div class="sd-val">48h</div>
          <div class="sd-label">PDS turnaround</div>
        </div>
        <div class="sd-item">
          <div class="sd-val">14</div>
          <div class="sd-label">Metrics scored</div>
        </div>
        <div class="sd-item">
          <div class="sd-val">4.2K+</div>
          <div class="sd-label">Comparison pool</div>
        </div>
      </div>
      <div class="success-actions">
        <a href="nexttier_landing.html" class="btn-primary-lg">Back to home</a>
        <a href="#" class="btn-outline-lg" onclick="location.reload()">Submit another profile</a>
      </div>
