<script>
let currentStep = 1;

function goToStep(n) {
  // Update form sections
  document.querySelectorAll('.form-section').forEach(s => s.classList.remove('active'));
  const section = document.getElementById('step' + n);
  if (section) section.classList.add('active');

  // Update progress indicators
  document.querySelectorAll('.prog-step').forEach((el, i) => {
    el.classList.remove('active', 'done');
    if (i + 1 === n) el.classList.add('active');
    else if (i + 1 < n) el.classList.add('done');
  });

  currentStep = n;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function submitForm() {
  // Basic validation
  const email = document.getElementById('email').value;
  const consent = document.getElementById('consentData').checked;
  if (!email) { alert('Please enter your email address before submitting.'); return; }
  if (!consent) { alert('Please review and accept the data consent before submitting.'); return; }

  // Hide form, show success
  document.querySelectorAll('.form-section').forEach(s => s.style.display = 'none');
  document.getElementById('successPanel').classList.add('visible');
  document.getElementById('sidebar').style.display = 'none';
  document.querySelectorAll('.prog-step').forEach(el => { el.classList.remove('active'); el.classList.add('done'); });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function updateSummary() {
  const first = document.getElementById('firstName').value;
  const last = document.getElementById('lastName').value;
  const pos = document.getElementById('position').value;
  const team = document.getElementById('teamName').value;
  const league = document.getElementById('currentLeague').value;
  const goalEl = document.querySelector('input[name="goal"]:checked');
  const planEl = document.querySelector('input[name="plan"]:checked');
  const contact = document.getElementById('contactName').value;
  const email = document.getElementById('email').value;

  const goalLabels = { develop:'Long-term dev', junior:'Make junior', college:'College / NCAA', pro:'Professional' };
  const planLabels = { starter:'Starter — $29/mo', scout:'Scout — $59/mo', elite:'Elite — $99/mo', unsure:'Not sure yet' };

  set('sumName', first && last ? `${first} ${last}` : (first || null));
  set('sumPosition', pos || null);
  set('sumTeam', team || null);
  set('sumLeague', league || null);
  set('sumGoal', goalEl ? goalLabels[goalEl.value] : null);
  set('sumPlan', planEl ? planLabels[planEl.value] : null);
  set('sumContact', email || (contact || null));
}

function set(id, val) {
  const el = document.getElementById(id);
  if (!el) return;
  if (val) {
    el.innerHTML = val;
    el.classList.remove('empty');
  } else {
    el.innerHTML = '<span class="empty">—</span>';
  }
}

function updateTierReco() {
  const goalEl = document.querySelector('input[name="goal"]:checked');
  const league = document.getElementById('currentLeague').value;
  if (!goalEl) return;

  const goal = goalEl.value;
  let tier = 'Scout — $59/mo';
  let why = 'Monthly evaluations and a development roadmap will have the most impact at this stage.';

  if (goal === 'pro' || goal === 'college' || league === 'ncaa' || league === 'ushl') {
    tier = 'Elite — $99/mo';
    why = 'A live recruiting profile actively matched to college and pro scouts is essential at this level and goal.';
  } else if (goal === 'develop') {
    tier = 'Starter — $29/mo';
    why = 'At this stage, a baseline PDS and annual evaluations give you the benchmarks to track progress without over-investing.';
  }

  document.getElementById('trbTierName').textContent = tier;
  document.getElementById('trbTierWhy').textContent = why;
  document.getElementById('tierRecoBlock').classList.add('visible');
}

function addHistoryRow() {
  const container = document.getElementById('historyRows');
  const row = document.createElement('div');
  row.className = 'history-row';
  row.style.marginBottom = '14px';
  row.innerHTML = `<div class="form-row-3">
    <div class="form-group" style="margin-bottom:0">
      <label>Season</label>
      <select><option>2024–25</option><option>2023–24</option><option>2022–23</option><option>2021–22</option><option>2020–21</option><option>Earlier</option></select>
    </div>
    <div class="form-group" style="margin-bottom:0">
      <label>Team / League</label>
      <input type="text" placeholder="e.g. Sherwood Park / AEHL">
    </div>
    <div class="form-group" style="margin-bottom:0">
      <label>Points (GP)</label>
      <input type="text" placeholder="e.g. 22 pts, 30 GP">
    </div>
  </div>`;
  container.appendChild(row);
}

// Show/hide other league field
document.getElementById('currentLeague').addEventListener('change', function() {
  document.getElementById('otherLeagueField').style.display = this.value === 'other' ? 'block' : 'none';
});
</script>
